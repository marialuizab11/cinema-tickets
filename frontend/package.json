    "@ng-select/ng-select": "^21.4.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "jwt-decode": "^4.0.0",
    "ngx-mask": "^21.0.1",
    "rxjs": "~7.8.0",
    "sweetalert2": "^11.26.18",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.2",
